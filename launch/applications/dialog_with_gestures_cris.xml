<application>
    <name>dialog_gesture_cris_demo</name>

    <module>
        <name>yarprobotinterface</name>
        <parameters>--context speechPipeline --from micAudio.ini --mic_sound_on_stop 0 --mic_start 0 --mic_min_samples 4000 --mic_max_samples 4000</parameters>
        <node>r1-torso</node>
    </module>

    <module>
        <name>sileroVAD</name>
        <parameters>--vad_threshold 0.6 --vad_gap_allowance 42</parameters>
        <environment>YARP_LOG_PROCESS_LABEL=VAD</environment>
        <node>console-llm</node>
    </module>

    <module>
        <name>yarprobotinterface</name>
        <parameters>--context vadModule --from audioPlayer.ini</parameters>
        <node>r1-face</node>
    </module>

    <module>
        <name>yarprobotinterface</name>
        <parameters>--context dialog_demo --from contextManagerChat.ini</parameters>
        <environment></environment>
        <node>console-llm</node>
    </module>

    <module>
        <name>yarprobotinterface</name>
        <parameters>--context dialog_demo --from crisChat.ini </parameters>
        <environment></environment>
        <node>console-llm</node>
    </module>

    <module>
        <name>yarprobotinterface</name>
        <parameters>--context dialog_demo --from r1Chat.ini</parameters>
        <environment></environment>
        <node>console-llm</node>
    </module>

    <module>
        <name>yarprobotinterface</name>
        <parameters>--context google --from googleSynthesizer.ini --synthesis_lang it-IT --synthesis_voice it-IT-Neural2-A</parameters>
        <environment></environment>
        <node>console-llm</node>
    </module>

    <module>
        <name>yarprobotinterface</name>
        <parameters>--context google --from googleTranscription.ini --transcription_lang en-US</parameters>
        <environment></environment>
        <node>console-llm</node>
    </module>

    <module>
        <name>faceExpressionImage5GTour</name>
        <parameters></parameters>
        <workdir></workdir>
        <node>r1-base</node>
    </module>

    <module>
        <name>yarprobotinterface</name>
        <parameters>--context headSynchronizer --from faceDisplay.ini</parameters>
        <workdir></workdir>
        <node>r1-face</node>
    </module>

    <module>
        <name>yarpActionsPlayer</name>
        <parameters>--filename configuration.ini --execute</parameters>
        <workdir>/home/r1-user/UC3/conf/animations</workdir>
        <node>r1-torso</node>
    </module>

    <module>
        <name>yarpAudioPlayer</name>
        <parameters></parameters>
        <workdir>/home/user1/UC3/conf/</workdir>
        <node>bt</node>
    </module>

    <module>
        <name>yarprobotinterface</name>
        <parameters>--context headSynchronizer --from faceDisplay.ini</parameters>
        <workdir></workdir>
        <node>r1-face</node>
    </module>

    <module>
        <name>ros2_speech_to_text_component</name>
        <parameters>run speech_to_text_component speech_to_text_component</parameters>
        <workdir>/home/user1/UC3</workdir>
        <node>bt</node>
    </module>

    <module>
        <name>ros2_text_to_speech_component</name>
        <parameters>run text_to_speech_component text_to_speech_component --from text_to_speech_config.ini</parameters>
        <workdir>/home/user1/UC3/src/components/text_to_speech_component/config</workdir>
        <node>bt</node>
    </module>

    <module>
        <name>ros2_dance_component</name>
        <parameters>run dance_component dance_component movements.json</parameters>
        <workdir>/home/user1/UC3/conf/</workdir>
        <node>bt</node>
    </module>

    <module>
        <name>ros2_execute_dance_component</name>
        <parameters>run execute_dance_component execute_dance_component</parameters>
        <node>bt</node>
    </module>

    <module>
        <name>ros2_cartesian_pointing_component</name>
        <parameters>run cartesian_pointing_component cartesian_pointing_component --context r1_cartesian_control --artworks yarp-contexts/contexts/r1_cartesian_control/artwork_coords.json</parameters>
        <workdir>/home/user1/UC3/</workdir>
        <node>bt</node>
    </module>

    <module>
        <name>ros2_cpp_dialog_component</name>
        <parameters>run dialog_component dialog_component --from config.ini</parameters>
        <workdir>/home/user1/UC3/src/components/dialog_component/cpp_dialog_component/config</workdir>
        <node>bt</node>
    </module>
    
    <module>
        <name>ros2_dialog_skill</name>
        <parameters>run dialog_skill dialog_skill</parameters>
        <workdir />
        <node>bt</node>
    </module>

    <module>
        <name>ros2</name>
        <parameters>run rag_server rag_node --ros-args --params-file src/config/rag_node.yaml</parameters>
        <workdir>/home/user1/rag_baseline/rag_ws</workdir>
        <node>bt-host</node>
    </module>

    <!-- <connection>
        <from>/audioRecorder_nws/audio:o</from>
        <to>/wake/audio:i</to>
    </connection> -->

    <connection>
        <from>/audioRecorder_nws/audio:o</from>
        <to>/vad/audio:i</to>
    </connection>

    <!-- <connection>
        <from>/vad/rpc:o</from>
        <to>/wake/rpc:i</to>
        <protocol>fast_tcp</protocol>
    </connection> -->

    <!-- <connection>
        <from>/wake/notification:o</from>
        <to>/wake_notification:i</to>
        <protocol>fast_tcp</protocol>
    </connection> -->
    
    <!-- <connection>
        <from>/wake/face:o</from>
        <to>/faceExpressionImage/rpc </to>
        <protocol>fast_tcp</protocol>
    </connection> -->

    <connection>
        <from>/vad/audio:o</from>
        <to>/SpeechToTextComponent/audio:i</to>
    </connection>

    <connection>
        <from>/SpeechToTextComponent/text:o</from>
        <to>/DialogComponent/SpeechToTextClient:i</to>
    </connection>

    <connection>
        <from>/TextToSpeechComponent/batch:o</from>
        <to>/DialogComponent/batch:i</to>
    </connection>

    <connection>
        <from>/DialogComponent/audio:o</from>
        <to>/audioPlayerWrapper/audio:i</to>
    </connection>

    <connection>
        <from>/audioPlayerWrapper/status:o</from>
        <to>/TextToSpeechComponent/audioPlayerWrapper/status:i</to>
    </connection>

    <connection>
    <from>/faceExpressionImage/image:o</from>
    <to>/robot/faceDisplay/image:i</to>
    <protocol>fast_tcp</protocol>
  </connection>

  <connection>
    <from>/audioPlayerWrapper/status:o</from>
    <to>/faceExpressionImage/mouthAudioData:i </to>
    <protocol>fast_tcp</protocol>
  </connection>

  <connection>
    <from>/audioRecorder_nws/status:o</from>
    <to>/faceExpressionImage/earsAudioStatus:i</to>
    <protocol>fast_tcp</protocol>
  </connection>

  <connection>
    <from>/DialogComponent/FaceExpressionClient/rpc:o</from>
    <to>/faceExpressionImage/rpc</to>
    <protocol>fast_tcp</protocol>
  </connection>

  <connection>
    <from>/audioRecorder_nws/audio:o</from>
    <to>/faceExpressionImage/earsAudioData:i</to>
    <protocol>fast_tcp+recv.portmonitor+file.soundfilter_resample+type.dll+channel.0+frequency.16000</protocol>
  </connection>

</application>
